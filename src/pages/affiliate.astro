---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

const title = 'Gema Salud Animal - Referidos';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="/favicon.png">
</head>
<body class="bg-[#1a1625] text-white antialiased font-display overflow-x-hidden min-h-screen">
  <div class="fixed inset-0 bg-gradient-to-br from-[#1a1625] via-[#2d1b4e] to-[#1a1625]"></div>
  <div class="fixed top-1/4 right-1/4 w-80 h-80 bg-primary/20 rounded-full blur-[120px]"></div>
  <div class="fixed bottom-1/4 left-1/4 w-80 h-80 bg-purple-600/10 rounded-full blur-[120px]"></div>

  <main class="relative z-10 min-h-screen flex items-center justify-center px-4 py-8">
    <section class="w-full max-w-2xl bg-white/5 border border-white/10 rounded-3xl shadow-2xl p-6 sm:p-8 backdrop-blur-md">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-14 h-14">
          <Image
            src={logo}
            alt="Gema Salud Animal Logo"
            class="w-full h-full object-contain"
            loading="eager"
          />
        </div>
        <div>
          <p class="text-primary text-xs font-bold uppercase tracking-wider">Programa de referidos</p>
          <h1 class="text-2xl sm:text-3xl font-black leading-tight">Vista previa del código</h1>
        </div>
      </div>

      <p class="text-slate-300 text-sm sm:text-base leading-relaxed mb-6">
        Esta pantalla previsualiza el código de referido del veterinario o especialista leído desde el QR.
      </p>

      <div class="bg-black/30 border border-white/10 rounded-2xl p-5 sm:p-6 space-y-4">
        <div>
          <p class="text-slate-400 text-xs uppercase tracking-wider mb-2">Reference Code detectado</p>
          <p id="reference-code" class="text-primary text-2xl sm:text-3xl font-black tracking-widest break-all">-</p>
        </div>
        <div>
          <p class="text-slate-400 text-xs uppercase tracking-wider mb-2">URL previsualizada</p>
          <p id="preview-url" class="text-slate-200 text-sm sm:text-base font-semibold break-all">-</p>
        </div>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <a href="/" class="inline-flex items-center justify-center rounded-xl bg-white text-black font-bold py-3 px-4 hover:scale-[1.02] transition-transform">
          Ir al inicio
        </a>
        <a href="/open" class="inline-flex items-center justify-center rounded-xl bg-primary text-white font-bold py-3 px-4 hover:scale-[1.02] transition-transform">
          Ir a open
        </a>
      </div>
    </section>
  </main>

  <script>
    const queryParams = new URLSearchParams(window.location.search);
    const rawReferenceCode = queryParams.get('referenceCode')?.trim() || '';
    const referenceCode = rawReferenceCode || 'SIN-CODIGO';
    const previewUrl = `https://app.gemasa.com.ar/affiliate?referenceCode=${encodeURIComponent(referenceCode)}`;

    const referenceCodeElement = document.getElementById('reference-code');
    const previewUrlElement = document.getElementById('preview-url');

    if (referenceCodeElement) {
      referenceCodeElement.textContent = referenceCode;
    }

    if (previewUrlElement) {
      previewUrlElement.textContent = previewUrl;
    }
  </script>
</body>
</html>
