---
import { Image } from 'astro:assets';
import appMobile from '../assets/app-mobile.jpeg';
import logo from '../assets/logo.png';

const title = "Gema Salud Animal - Descarga nuestra App";
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="/favicon.png">
  <style>
    @keyframes border-flow {
      0% {
        background-position: 0% 50%;
      }
      100% {
        background-position: 200% 50%;
      }
    }
    
    .animated-border {
      position: relative;
      background: linear-gradient(90deg, 
        transparent 0%, 
        transparent 40%, 
        rgba(140, 43, 238, 0.8) 50%, 
        rgba(168, 85, 247, 1) 55%,
        rgba(140, 43, 238, 0.8) 60%, 
        transparent 70%, 
        transparent 100%
      );
      background-size: 200% 100%;
      animation: border-flow 3s linear infinite;
      padding: 2px;
      border-radius: 9999px;
    }
    
    .animated-border-inner {
      background: rgba(140, 43, 238, 0.1);
      border-radius: 9999px;
      padding: 0.375rem 1rem;
    }
    
    /* Animaciones de gemas flotantes */
    @keyframes float-gem {
      0% {
        transform: translateY(100vh) rotate(0deg);
        opacity: 0;
      }
      10% {
        opacity: 1;
      }
      90% {
        opacity: 1;
      }
      100% {
        transform: translateY(-100vh) rotate(360deg);
        opacity: 0;
      }
    }
    
    @keyframes twinkle {
      0%, 100% {
        opacity: 0.3;
        transform: scale(1);
      }
      50% {
        opacity: 1;
        transform: scale(1.2);
      }
    }
    
    .gem {
      position: fixed;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      filter: blur(1px);
      animation: float-gem linear infinite;
      box-shadow: 0 0 10px currentColor, 0 0 20px currentColor;
      z-index: 1;
    }
    
    .gem::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 4px;
      height: 4px;
      background: white;
      border-radius: 50%;
      animation: twinkle 2s ease-in-out infinite;
    }
    
    /* Colores de gemas */
    .gem-ruby { color: #E0115F; } /* Rubí */
    .gem-sapphire { color: #0F52BA; } /* Zafiro */
    .gem-emerald { color: #50C878; } /* Esmeralda */
    .gem-diamond { color: #B9F2FF; } /* Diamante */
    .gem-amethyst { color: #9966CC; } /* Amatista */
    .gem-topaz { color: #FFC87C; } /* Topacio */
    .gem-aquamarine { color: #7FFFD4; } /* Aguamarina */
  </style>
</head>
<body class="bg-[#1a1625] text-white antialiased font-display overflow-x-hidden">
  <!-- Gemas flotantes - Fondo completo -->
  <div id="gems-container" class="fixed inset-0 overflow-hidden pointer-events-none z-0"></div>
  
  <div class="relative min-h-screen flex items-center justify-center px-4 sm:px-6 py-8 sm:py-12">
    <!-- Background gradient effect -->
    <div class="absolute inset-0 bg-gradient-to-br from-[#1a1625] via-[#2d1b4e] to-[#1a1625]"></div>
    <div class="absolute top-1/4 right-1/4 w-64 h-64 sm:w-96 sm:h-96 bg-primary/20 rounded-full blur-[100px] sm:blur-[120px]"></div>
    <div class="absolute bottom-1/4 left-1/4 w-64 h-64 sm:w-96 sm:h-96 bg-purple-600/10 rounded-full blur-[100px] sm:blur-[120px]"></div>
    
    <div class="relative z-10 max-w-6xl mx-auto w-full">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        <!-- Left Content -->
        <div class="space-y-6 sm:space-y-8 text-center lg:text-left">
          <!-- Logo + Badge -->
          <div class="flex flex-col lg:flex-row items-center lg:items-center justify-center lg:justify-start gap-4 lg:gap-6">
            <!-- Logo -->
            <div class="w-16 h-16 lg:w-20 lg:h-20 flex-shrink-0">
              <Image 
                src={logo} 
                alt="Gema Salud Animal Logo" 
                class="w-full h-full object-contain"
                loading="eager"
              />
            </div>
            
            <!-- Badge with animated border -->
            <div class="animated-border">
              <div class="animated-border-inner flex items-center gap-2">
                <span class="size-2 bg-primary rounded-full animate-pulse"></span>
                <span class="text-primary text-[10px] sm:text-xs font-bold uppercase tracking-wider whitespace-nowrap">Versión 1.0 de Lanzamiento</span>
              </div>
            </div>
          </div>
          
          <!-- Heading -->
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.1] tracking-tight">
            Descarga<br>nuestra <span class="text-primary">App</span>
          </h1>
          
          <!-- Description -->
          <p class="text-slate-400 text-base sm:text-lg lg:text-xl leading-relaxed max-w-xl mx-auto lg:mx-0">
            Gestiona la salud de tus mascotas, accede a su ID digital y agenda citas médicas en segundos. Todo el cuidado de Gema Salud Animal en la palma de tu mano.
          </p>
          
          <!-- Phone Mockup - Solo visible en mobile -->
          <div class="relative flex justify-center lg:hidden my-8">
            <!-- Glow effect behind phone -->
            <div class="absolute inset-0 bg-gradient-to-br from-primary/30 via-purple-600/20 to-transparent rounded-full blur-3xl"></div>
            
            <!-- Phone Frame Container -->
            <div class="relative w-full max-w-[280px] sm:max-w-[320px]">
              <!-- Phone Frame -->
              <div class="relative aspect-[9/19.5] w-full">
                <!-- Phone Border/Frame -->
                <div class="absolute inset-0 bg-slate-900 rounded-[2.5rem] sm:rounded-[3rem] shadow-2xl p-2 sm:p-3">
                  <!-- Notch -->
                  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 sm:w-36 h-6 sm:h-7 bg-slate-900 rounded-b-3xl z-10"></div>
                  
                  <!-- Screen Container -->
                  <div class="relative w-full h-full bg-black rounded-[2rem] sm:rounded-[2.5rem] overflow-hidden">
                    <!-- App Screenshot -->
                    <Image 
                      src={appMobile} 
                      alt="Gema Salud Animal App Preview" 
                      class="w-full h-full object-cover"
                      loading="eager"
                    />
                  </div>
                </div>
                
                <!-- Phone Shine Effect -->
                <div class="absolute inset-0 bg-gradient-to-br from-white/5 via-transparent to-transparent rounded-[2.5rem] sm:rounded-[3rem] pointer-events-none"></div>
              </div>
            </div>
          </div>
          
          <!-- Store Buttons -->
          <div class="flex flex-row gap-3 justify-center lg:justify-start max-w-2xl mx-auto lg:mx-0">
            <!-- App Store Button -->
            <a 
              href="https://apps.apple.com/app/gema-salud-animal/id6754624337" 
              class="group flex flex-col sm:flex-row items-center justify-center gap-2 bg-white text-black px-4 sm:px-6 py-3 sm:py-4 rounded-xl sm:rounded-2xl font-bold hover:scale-105 transition-all shadow-xl hover:shadow-2xl flex-1 sm:flex-initial"
            >
              <svg class="size-8 sm:size-8" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              <div class="text-center sm:text-left">
                <div class="text-[10px] sm:text-[10px] uppercase font-semibold opacity-70 tracking-wide">Descarga en</div>
                <div class="text-sm sm:text-xl leading-none font-black sm:hidden">App Store</div>
                <div class="hidden sm:block text-xl leading-none font-black">App Store</div>
              </div>
            </a>
            
            <!-- Google Play Button -->
            <a 
              href="https://play.google.com/store/apps/details?id=com.gemasalud.gemasaludapp&pli=1" 
              class="group flex flex-col sm:flex-row items-center justify-center gap-2 bg-white text-black px-4 sm:px-6 py-3 sm:py-4 rounded-xl sm:rounded-2xl font-bold hover:scale-105 transition-all shadow-xl hover:shadow-2xl flex-1 sm:flex-initial"
            >
              <svg class="size-8 sm:size-8" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
              </svg>
              <div class="text-center sm:text-left">
                <div class="text-[10px] sm:text-[10px] uppercase font-semibold opacity-70 tracking-wide">Disponible en</div>
                <div class="text-sm sm:text-xl leading-none font-black sm:hidden">Google Play</div>
                <div class="hidden sm:block text-xl leading-none font-black">Google Play</div>
              </div>
            </a>
          </div>
        </div>
        
        <!-- Right - Phone Mockup with Frame (Solo desktop) -->
        <div class="relative hidden lg:flex justify-center lg:justify-end">
          <!-- Glow effect behind phone -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary/30 via-purple-600/20 to-transparent rounded-full blur-3xl"></div>
          
          <!-- Phone Frame Container -->
          <div class="relative w-full max-w-[360px]">
            <!-- Phone Frame -->
            <div class="relative aspect-[9/19.5] w-full">
              <!-- Phone Border/Frame -->
              <div class="absolute inset-0 bg-slate-900 rounded-[3rem] shadow-2xl p-3">
                <!-- Notch -->
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-36 h-7 bg-slate-900 rounded-b-3xl z-10"></div>
                
                <!-- Screen Container -->
                <div class="relative w-full h-full bg-black rounded-[2.5rem] overflow-hidden">
                  <!-- App Screenshot -->
                  <Image 
                    src={appMobile} 
                    alt="Gema Salud Animal App Preview" 
                    class="w-full h-full object-cover"
                    loading="eager"
                  />
                </div>
              </div>
              
              <!-- Phone Shine Effect -->
              <div class="absolute inset-0 bg-gradient-to-br from-white/5 via-transparent to-transparent rounded-[3rem] pointer-events-none"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Crear gemas flotantes
    const gemsContainer = document.getElementById('gems-container');
    const gemColors = ['ruby', 'sapphire', 'emerald', 'diamond', 'amethyst', 'topaz', 'aquamarine'];
    const gemCount = 40; // Número de gemas (aumentado para cubrir toda la pantalla)
    
    function createGem() {
      const gem = document.createElement('div');
      gem.className = `gem gem-${gemColors[Math.floor(Math.random() * gemColors.length)]}`;
      
      // Posición horizontal aleatoria
      gem.style.left = `${Math.random() * 100}%`;
      
      // Duración aleatoria entre 15 y 30 segundos
      const duration = 15 + Math.random() * 15;
      gem.style.animationDuration = `${duration}s`;
      
      // Delay aleatorio para que no todas empiecen al mismo tiempo
      gem.style.animationDelay = `${Math.random() * 10}s`;
      
      // Tamaño aleatorio
      const size = 6 + Math.random() * 8;
      gem.style.width = `${size}px`;
      gem.style.height = `${size}px`;
      
      gemsContainer.appendChild(gem);
      
      // Remover y recrear la gema después de que termine la animación
      setTimeout(() => {
        gem.remove();
        createGem();
      }, (duration + parseFloat(gem.style.animationDelay)) * 1000);
    }
    
    // Crear gemas iniciales
    for (let i = 0; i < gemCount; i++) {
      setTimeout(() => createGem(), i * 300);
    }
    
    // Detectar plataforma
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
    const isAndroid = /Android/.test(navigator.userAgent);
    
    // Obtener parámetros de la URL
    const urlParams = new URLSearchParams(window.location.search);
    const path = urlParams.get('path') || '';
    const params = window.location.search;
    
    // Construir deep link
    let deepLink;
    if (path) {
      deepLink = `https://app.gemasa.com.ar${path}${params}`;
    } else {
      deepLink = 'gemasalud://';
    }
    
    console.log('Deep link:', deepLink);
    console.log('Platform:', { isIOS, isAndroid });
    
    // Intentar abrir la app automáticamente después de 1 segundo
    setTimeout(() => {
      window.location.href = deepLink;
      
      // Fallback con custom scheme
      if (!deepLink.startsWith('https://')) {
        setTimeout(() => {
          window.location.href = `gemasalud://${path}${params}`;
        }, 500);
      }
    }, 1000);
  </script>
</body>
</html>
